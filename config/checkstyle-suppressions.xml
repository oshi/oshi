<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
        "https://checkstyle.org/dtds/suppressions_1_0.dtd">

<suppressions>
    <suppress checks=".*" files="[\\/]demo[\\/].*"/>
    <suppress checks=".*" files="[\\/]benchmark[\\/].*"/>
    <suppress checks=".*" files="[\\/]comparison[\\/].*"/>

    <!-- Intentional style breaks -->
    <suppress checks="ConstantName" files="ParseUtil\.java" lines="116-136"/>
    <suppress checks="VisibilityModifier" files="SmcUtil\.java"/>

    <!-- JNA convention  -->
    <suppress checks="InterfaceIsType" files="[\\/]jna[\\/].*"/>
    <suppress checks="VisibilityModifier" files="[\\/]jna[\\/].*"/>

    <suppress checks="ConstantName" files="[\\/]jna[\\/].*"/>
    <suppress checks="MemberName" files="[\\/]jna[\\/].*"/>
    <suppress checks="MethodName" files="[\\/]jna[\\/].*"/>
    <suppress checks="ParameterName" files="[\\/]jna[\\/].*"/>
    <suppress checks="TypeName" files="[\\/]jna[\\/].*"/>

    <!-- FFM convention -->
    <suppress checks="InterfaceIsType" files="[\\/]ffm[\\/].*"/>
    <suppress checks="ConstantName" files="[\\/]ffm[\\/].*"/>
    <suppress checks="MethodName" files="[\\/]ffm[\\/].*"/>
    <suppress checks="ParameterName" files="[\\/]ffm[\\/].*"/>
    <suppress checks="RecordComponentName" files=".*FFM\.java"/>
    <suppress checks="LocalVariableName" files=".*FFM\.java"/>
    <suppress checks="LocalFinalVariableName" files=".*FFM\.java"/>

    <!-- Solaris /proc struct mirrors: pr_* / tv_* fields and public visibility match the kernel struct
         layout (psinfo_t / lwpsinfo_t / prusage_t / timestruc_t in <sys/procfs.h>). Shared between the
         JNA and FFM drivers, so they live in oshi-common. -->
    <suppress checks="MemberName" files="(SolarisPsInfo|SolarisLwpsInfo|SolarisPrUsage|SolarisTimestruc)\.java"/>
    <suppress checks="VisibilityModifier" files="(SolarisPsInfo|SolarisLwpsInfo|SolarisPrUsage|SolarisTimestruc)\.java"/>

    <!-- AIX /proc struct mirrors: pr_* / tv_* fields and public visibility match the kernel struct
         layout (psinfo_t / lwpsinfo_t / timestruc_t in <sys/procfs.h>). Shared between the JNA and
         FFM drivers, so they live in oshi-common. -->
    <suppress checks="MemberName" files="(AixPsInfo|AixLwpsInfo|Timestruc)\.java"/>
    <suppress checks="VisibilityModifier" files="(AixPsInfo|AixLwpsInfo|Timestruc)\.java"/>

    <!-- Apple naming convention for CoreGraphics constants (kCG prefix) -->
    <suppress checks="ConstantName" files="WindowInfoFFM\.java"/>

    <!-- AIX perfstat field accessors: ~80 trivial getters reading C struct fields at fixed byte
         offsets. Method-level @param/@return tags would duplicate the field comment already on
         each method. -->
    <suppress checks="JavadocMethod" files="PerfstatFunctions\.java"/>

    <!-- AIX FFM driver POJOs mirror libperfstat struct field names verbatim (snake_case) so the
         JNA and FFM consumer code reads identically. -->
    <suppress checks="MemberName" files="Perfstat[a-zA-Z]+FFM\.java"/>
    <suppress checks="VisibilityModifier" files="Perfstat[a-zA-Z]+FFM\.java"/>
    <suppress checks="JavadocMethod" files="PsInfoFFM\.java"/>

    <!-- AIX shared HAL/OS abstract bases use public data POJOs (CpuTickRow, CpuTotalRow,
         PartitionInfo, IfStats, DiskStats) and protected final fields (lscfg supplier) that match
         the C struct field names rather than camelCase getters. -->
    <suppress checks="MemberName" files="(AixCentralProcessor|AixHWDiskStore|AixNetworkIF|AixGlobalMemory)\.java"/>
    <suppress checks="VisibilityModifier" files="(AixCentralProcessor|AixHWDiskStore|AixNetworkIF|AixGlobalMemory)\.java"/>

    <!-- Solaris shared HAL abstract bases use public data POJOs (DiskStats, IfStats, BatteryReadings)
         for the kstat I/O, interface, and battery counters that the JNA and FFM subclasses populate. -->
    <suppress checks="VisibilityModifier" files="(SolarisHWDiskStore|SolarisNetworkIF|SolarisPowerSource)\.java"/>

    <!-- Package-info is in other source tree -->
    <suppress checks="JavadocPackage" files=".*FFM\.java"/>

    <!-- Protected final fields initialized in constructor -->
    <suppress checks="VisibilityModifier" files="MacOperatingSystem\.java" lines="54-61"/>

    <!-- Imports for classes linked in javadocs -->
    <suppress checks="UnusedImports" files="(CentralProcessor|OSDesktopWindow|OSProcess)\.java"/>
    <!-- Test files -->
    <suppress checks="(JavadocPackage|MemberName|ConstantName|StaticVariableName)" files="(.*Test|TestConstants)\.java"/>
    <suppress checks="(ConstantName|VisibilityModifier)" files="SystemInfoTest\.java"/>
    <suppress checks="(VisibilityModifier)" files="OperatingSystemTest\.java"/>
</suppressions>
